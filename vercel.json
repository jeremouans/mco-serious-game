{
  "rewrites": [
    { "source": "/",              "destination": "/src/index.html" },
    { "source": "/host",          "destination": "/src/host/index.html" },
    { "source": "/host/(.*)",     "destination": "/src/host/$1" },
    { "source": "/join",          "destination": "/src/join/index.html" },
    { "source": "/join/(.*)",     "destination": "/src/join/$1" },
    { "source": "/admin",         "destination": "/src/admin/index.html" },
    { "source": "/admin/(.*)",    "destination": "/src/admin/$1" },
    { "source": "/lib/(.*)",      "destination": "/src/lib/$1" },
    { "source": "/data/(.*)",     "destination": "/src/data/$1" },
    { "source": "/assets/(.*)",   "destination": "/src/assets/$1" }
  ]
}
